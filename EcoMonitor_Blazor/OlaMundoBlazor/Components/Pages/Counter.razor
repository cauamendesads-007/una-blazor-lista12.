@page "/counter"
@rendermode InteractiveServer

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status" style="color: @GetCounterColor(); font-weight: bold; font-size: 1.2rem;">
    Current count: @currentCount
</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    [Parameter]
    public int IncrementQuantia { get; set; } = 100;

    private void IncrementCount()
    {
        currentCount += IncrementQuantia;
    }

    // Lógica para definir a cor baseada no valor
    private string GetCounterColor()
    {
        if (currentCount > 200)
        {
            return "red";
        }
        else if (currentCount > 100)
        {
            return "orange"; // Amarelo (orange costuma ler melhor no fundo branco)
        }
        else
        {
            return "green";
        }
    }
}